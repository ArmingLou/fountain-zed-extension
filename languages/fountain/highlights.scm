; Fountain 语法高亮定义

; 场景标题
(scene_heading) @keyword

; 转场
(transition) @type

; 居中文本
(centered) @string

; 角色
(character) @attribute

; 括号说明
(parenthetical) @comment

; 对白
(dialogue) @string

; 动作描述
(action) @string

; 章节标题
(section_heading) @heading

; 概要
(synopsis) @comment

; 标题页
(title_page) @heading
(title_page_field) @heading

; 歌词
(lyric) @string.special

; 笔记/注释
(note) @comment

; 注释块
(boneyard) @comment

; 分页符
(page_break) @punctuation
(page_break_marker) @punctuation

; 场景位置
(scene_location) @variable

; 场景时间
(scene_time) @variable

; 场景号
(scene_number) @number

; 强制标记
(forced_character_start) @attribute
(forced_transition_start) @type
(forced_action_start) @string