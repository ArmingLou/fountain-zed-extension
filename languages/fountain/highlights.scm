; Fountain 语法高亮定义

; 场景标题 - 显著的标题样式
(scene_heading) @keyword

; 转场 - 类似关键字
(transition) @type

; 居中文本
(centered) @string

; 角色台词 - 强调
(character_line) @attribute

; 括号说明
(parenthetical) @comment

; 对白 - 正文
(dialogue) @string

; 动作描述
(action) @string

; 章节标题 - 类似标题
(section) @heading

; 概要
(synopsis) @comment

; 标题页
(title_page_line) @heading

; 歌词
(lyrics) @string.special

; 内联注释 - 类似注释
(note_inline) @comment

; 注释块 (boneyard)
(boneyard) @comment

; 分页符
(page_break) @punctuation

; 分隔符
(separator) @punctuation

; 场景位置
(scene_location) @variable